# Security and caching headers — served by Hostinger (LiteSpeed, .htaccess-compatible)

<IfModule mod_headers.c>
  # Security headers
  Header always set Strict-Transport-Security "max-age=31536000"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Videos: 30-day cache (filenames are stable, content rarely changes)
  <FilesMatch "\.(mp4|webm)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # Images and fonts: 7-day cache
  <FilesMatch "\.(webp|png|jpe?g|svg|ico|woff2?)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>

  # Hashed build assets (Astro _astro/*): immutable, 1 year
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
