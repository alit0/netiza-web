---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<article class:list={['card', className]}>
  <slot />
</article>

<style>
  .card {
    padding: var(--card-padding);
    border-radius: var(--card-radius);
    background: var(--card-bg);
    color: var(--card-text);
  }
</style>
