---
import darkLogo from '../../../design-handoff/logo-netiza-dark.svg';
import lightLogo from '../../../design-handoff/logo-netiza-light.svg';

interface Props {
  href?: string;
  class?: string;
}

const { href = '/', class: className } = Astro.props;
---

<a class:list={['logo', className]} href={href} aria-label="Netiza — go to homepage">
  <img class="logo__light-theme" src={darkLogo.src} alt="" width="139" height="26" />
  <img class="logo__dark-theme" src={lightLogo.src} alt="" width="139" height="26" />
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
  }

  .logo img {
    width: auto;
    height: var(--logo-height);
  }

  .logo__dark-theme {
    display: none;
  }

  :global([data-theme="dark"]) .logo__light-theme {
    display: none;
  }

  :global([data-theme="dark"]) .logo__dark-theme {
    display: block;
  }
</style>
