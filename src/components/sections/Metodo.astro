---
import Kicker from '../ui/Kicker.astro';
import Button from '../ui/Button.astro';
import { whatsappUrl, WHATSAPP_MESSAGES } from '../../data/links';
---

<section class="method section" aria-labelledby="method-title">
  <div class="method__inner">
    <Kicker>Método</Kicker>
    <h2 id="method-title" class="method__title">
      Primero entendemos. Después construimos lo que hace falta.
    </h2>
    <ol class="method__steps">
      <li class="method__step">
        <span class="method__num" aria-hidden="true">01</span>
        <div>
          <strong class="method__step-title">Relevamos</strong>
          <span class="method__step-desc">Tu negocio, objetivos, canales y lo que hoy te frena.</span>
        </div>
      </li>
      <li class="method__step">
        <span class="method__num" aria-hidden="true">02</span>
        <div>
          <strong class="method__step-title">Diagnosticamos</strong>
          <span class="method__step-desc">Cómo te ven desde afuera: web, redes, mensajes y procesos.</span>
        </div>
      </li>
      <li class="method__step">
        <span class="method__num" aria-hidden="true">03</span>
        <div>
          <strong class="method__step-title">Priorizamos</strong>
          <span class="method__step-desc">Qué resolver primero, según impacto, urgencia y presupuesto.</span>
        </div>
      </li>
      <li class="method__step">
        <span class="method__num" aria-hidden="true">04</span>
        <div>
          <strong class="method__step-title">Creamos e implementamos</strong>
          <span class="method__step-desc">Web, estrategia, comunicación, automatizaciones o IA, según lo que toque.</span>
        </div>
      </li>
    </ol>
    <footer class="method__footer">
      <p class="method__closing">Sin paquetes cerrados ni precios de lista: te armamos una propuesta para lo que necesitás ahora, con un camino claro para lo que viene después.</p>
      <Button variant="ghost" href={whatsappUrl(WHATSAPP_MESSAGES.metodo)} target="_blank" rel="noopener">
        Hablar sobre mi proyecto
      </Button>
    </footer>
  </div>
</section>

<style>
  .method {
    padding-block: var(--space-section-y);
  }

  .method__inner {
    max-width: 1072px;
    margin: 0 auto;
  }

  .method__title {
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-medium);
    line-height: 1.12;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
    margin: var(--space-6) 0 var(--space-12);
  }

  .method__steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
    list-style: none;
    margin: 0 0 var(--space-8);
    padding: 0;
  }

  .method__step {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--card-padding);
    border-radius: var(--card-radius);
    background: var(--card-bg);
  }

  .method__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-sm);
    background: var(--button-primary-bg);
    color: var(--button-primary-text);
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-semibold);
  }

  .method__step-title {
    display: block;
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-medium);
    line-height: 1.3;
    color: var(--color-text-primary);
    margin-bottom: var(--space-1);
  }

  .method__step-desc {
    display: block;
    font-size: var(--font-size-base);
    line-height: 1.5;
    color: var(--color-text-secondary);
  }

  .method__footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }

  .method__closing {
    font-size: var(--font-size-md);
    line-height: 1.5;
    color: var(--color-text-secondary);
    text-align: center;
    max-width: 56ch;
    margin: 0;
  }

  @media (max-width: 809px) {
    .method__inner {
      padding-inline: var(--space-6);
    }

    .method__title {
      font-size: var(--font-size-xl);
      line-height: 1.12;
      letter-spacing: -0.05em;
    }

    .method__steps {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }
  }
</style>
