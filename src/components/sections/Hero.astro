---
import Kicker from '../ui/Kicker.astro';
import Button from '../ui/Button.astro';
import MediaSlot from '../ui/MediaSlot.astro';
import { whatsappUrl, WHATSAPP_MESSAGES } from '../../data/links';
---

<section class="hero section" aria-labelledby="hero-title">
  <div class="hero__grid">
    <div class="hero__copy">
      <Kicker>Estrategia digital, web e IA para empresas en crecimiento</Kicker>
      <h1 id="hero-title" class="hero__title">
        Tu negocio se ve más <span class="accent">chico</span> de lo que es.
      </h1>
      <p class="hero__lead">
        Hacés las cosas bien, pero online no se nota. En Netiza ordenamos tu presencia digital para que te encuentren, entiendan qué hacés en dos minutos y te escriban con confianza.
      </p>
      <div class="hero__actions">
        <Button href={whatsappUrl(WHATSAPP_MESSAGES.hero)} target="_blank" rel="noopener">
          Hablar sobre mi proyecto
        </Button>
        <Button variant="ghost" href="#que-hacemos">
          Ver qué hacemos
        </Button>
        <span class="hero__microcopy">Cada proyecto se cotiza según lo que necesitás.<br>Te respondemos dentro de las 24 hs. Sin compromiso.</span>
      </div>
    </div>
    <div class="hero__media">
      <MediaSlot label="Reel vertical de contenido producido por Netiza">
        <div class="hero__slider">
          <div class="hero__track">
            <video
              class="hero__video"
              src="/assets/slide1.mp4"
              poster="/assets/slide1-poster.webp"
              width="342"
              height="608"
              muted playsinline loop preload="metadata"
              aria-hidden="true"
            ></video>
            <video
              class="hero__video"
              src="/assets/slide2.mp4"
              poster="/assets/slide2-poster.webp"
              width="342"
              height="608"
              muted playsinline loop preload="none"
              aria-hidden="true"
            ></video>
            <video
              class="hero__video"
              src="/assets/slide3.mp4"
              poster="/assets/slide3-poster.webp"
              width="342"
              height="608"
              muted playsinline loop preload="none"
              aria-hidden="true"
            ></video>
          </div>
          <p class="hero__overlay-title" aria-hidden="true">
            <span class="hero__overlay-text">Tu negocio se ve más <span class="accent">chico</span> de lo que es.</span>
          </p>
          <div class="hero__dots" role="group" aria-label="Selector de reel">
            <button class="hero__dot" type="button" data-slide="0" aria-label="Ver reel 1" aria-current="true"></button>
            <button class="hero__dot" type="button" data-slide="1" aria-label="Ver reel 2" aria-current="false"></button>
            <button class="hero__dot" type="button" data-slide="2" aria-label="Ver reel 3" aria-current="false"></button>
          </div>
        </div>
      </MediaSlot>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: var(--space-section-y);
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 1fr 342px;
    gap: var(--space-16);
    align-items: center;
    max-width: 1072px;
    margin: 0 auto;
  }

  .hero__copy {
    max-width: 60ch;
  }

  .hero__title {
    font-size: var(--font-size-5xl);
    font-weight: var(--font-weight-medium);
    line-height: 1.08;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
    margin: var(--space-6) 0 var(--space-4);
  }

  .hero__lead {
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-medium);
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-8);
    max-width: 56ch;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4);
  }

  .hero__microcopy {
    display: block;
    width: 100%;
    margin-top: var(--space-2);
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .hero__media {
    max-width: 342px;
  }

  .hero__slider {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .hero__track {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
    transform: translateY(calc(var(--slide-index, 0) * -100%));
    transition: transform 600ms ease;
  }

  .hero__video {
    display: block;
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__overlay-title {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__track {
      transition: none;
    }
  }

  .hero__dots {
    position: absolute;
    top: 50%;
    right: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    transform: translateY(-50%);
  }

  /* 24x24 hit area per touch-target guidelines; the visible dot
     is the 8px ::before. */
  .hero__dot {
    position: relative;
    width: 24px;
    height: 24px;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
  }

  .hero__dot::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 8px;
    height: 8px;
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--color-base-white) 45%, transparent);
    transform: translate(-50%, -50%);
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .hero__dot[aria-current='true']::before {
    background: var(--color-base-white);
    transform: translate(-50%, -50%) scale(1.15);
  }

  @media (max-width: 809px) {
    .hero__grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
      padding-inline: var(--space-6);
    }

    /* Keep the real h1 in the accessibility tree; the visual title
       is the decorative overlay on top of the video. */
    .hero__title {
      position: absolute;
      width: 1px;
      height: 1px;
      margin: -1px;
      padding: 0;
      border: 0;
      overflow: hidden;
      clip-path: inset(50%);
      white-space: nowrap;
    }

    .hero__lead {
      font-size: var(--font-size-base);
    }

    .hero__actions {
      flex-direction: column;
      align-items: stretch;
    }

    .hero__media {
      order: -1;
      max-width: 100%;
    }

    /* Direct aspect-ratio override: MediaSlot sets its ratio variable via
       inline style, which would win over any stylesheet variable override. */
    .hero__media :global(.media-slot) {
      aspect-ratio: 342 / 440;
    }

    .hero__overlay-title {
      position: absolute;
      inset: 0;
      z-index: 1;
      display: flex;
      align-items: center;
      margin: 0;
      padding: 0 var(--space-6);
      font-size: clamp(2.125rem, 10.2vw, 2.5rem);
      font-weight: var(--font-weight-medium);
      line-height: 1.06;
      letter-spacing: -0.048em;
      color: var(--color-base-paper-light);
      text-shadow: 0 2px 24px rgba(0, 0, 0, 0.35);
      pointer-events: none;
    }
  }
</style>

<script>
  const slider = document.querySelector<HTMLDivElement>('.hero__slider');
  const track = document.querySelector<HTMLDivElement>('.hero__track');
  const videos = document.querySelectorAll<HTMLVideoElement>('.hero__video');
  const dots = document.querySelectorAll<HTMLButtonElement>('.hero__dot');

  if (slider && track && videos.length) {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const SLIDE_INTERVAL_MS = 6000;

    let activeIndex = 0;
    let intervalId: ReturnType<typeof setInterval> | null = null;
    let isVisible = true;

    const setActive = (index: number) => {
      activeIndex = index;
      track.style.setProperty('--slide-index', String(index));

      videos.forEach((video, i) => {
        dots[i]?.setAttribute('aria-current', String(i === index));

        if (i === index) {
          if (!prefersReducedMotion) {
            video.play().catch(() => {});
          }
        } else {
          video.pause();
        }
      });
    };

    const goToNext = () => {
      setActive((activeIndex + 1) % videos.length);
    };

    const startInterval = () => {
      if (prefersReducedMotion || intervalId !== null) return;
      intervalId = setInterval(goToNext, SLIDE_INTERVAL_MS);
    };

    const stopInterval = () => {
      if (intervalId !== null) {
        clearInterval(intervalId);
        intervalId = null;
      }
    };

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        setActive(i);
        stopInterval();
        if (isVisible) startInterval();
      });
    });

    if (prefersReducedMotion) {
      // No auto-advance, no autoplay: freeze on the first slide's poster.
      videos[0]?.pause();
      setActive(0);
    } else {
      setActive(0);

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            isVisible = entry.isIntersecting;
            if (isVisible) {
              startInterval();
              videos[activeIndex]?.play().catch(() => {});
            } else {
              stopInterval();
              videos.forEach((video) => video.pause());
            }
          });
        },
        { threshold: 0.1 }
      );
      observer.observe(slider);
    }
  }
</script>
