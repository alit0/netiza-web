---
import Kicker from '../ui/Kicker.astro';
import Button from '../ui/Button.astro';
import { whatsappUrl, WHATSAPP_MESSAGES } from '../../data/links';

// FormSubmit.co AJAX endpoint — sends submissions to the Netiza inbox.
// Uses FormSubmit's hashed alias (not the raw email) so the address is
// never exposed in the page source.
const FORM_ENDPOINT = 'https://formsubmit.co/ajax/7cd52732ca929d088a38947334da0adf';
const whatsappFallback = whatsappUrl(WHATSAPP_MESSAGES.cta);
---

<section class="contacto section" aria-labelledby="contacto-title">
  <div class="contacto__inner">
    <Kicker>Contacto</Kicker>
    <h2 id="contacto-title" class="contacto__title">¿Preferís dejarnos un mensaje?</h2>
    <p class="contacto__body">
      Completá el formulario y te respondemos por mail dentro de las 24 hs. Si querés algo más
      rápido, escribinos por WhatsApp.
    </p>

    <form class="contacto__form" action={FORM_ENDPOINT} method="POST" novalidate>
      <div class="contacto__field">
        <label class="contacto__label" for="contacto-nombre">Nombre</label>
        <input
          class="contacto__input"
          id="contacto-nombre"
          type="text"
          name="nombre"
          autocomplete="name"
          aria-describedby="contacto-nombre-error"
          required
        />
        <span class="contacto__error" id="contacto-nombre-error" role="alert"></span>
      </div>

      <div class="contacto__field">
        <label class="contacto__label" for="contacto-email">Email</label>
        <input
          class="contacto__input"
          id="contacto-email"
          type="email"
          name="email"
          autocomplete="email"
          inputmode="email"
          aria-describedby="contacto-email-error"
          required
        />
        <span class="contacto__error" id="contacto-email-error" role="alert"></span>
      </div>

      <div class="contacto__field">
        <label class="contacto__label" for="contacto-mensaje">Mensaje</label>
        <textarea
          class="contacto__input contacto__textarea"
          id="contacto-mensaje"
          name="mensaje"
          rows="4"
          aria-describedby="contacto-mensaje-error"
          required></textarea>
        <span class="contacto__error" id="contacto-mensaje-error" role="alert"></span>
      </div>

      {/* Honeypot — hidden from users; if filled, it's a bot. */}
      <input class="contacto__honey" type="text" name="_honey" tabindex="-1" autocomplete="off" aria-hidden="true" />
      <input type="hidden" name="_subject" value="Nuevo mensaje desde netiza.com.ar" />
      <input type="hidden" name="_template" value="table" />
      <input type="hidden" name="_captcha" value="false" />

      <Button type="submit">Enviar mensaje</Button>
      <p class="contacto__status" role="status" aria-live="polite" data-fallback={whatsappFallback}></p>
    </form>
  </div>

  {/* Success modal */}
  <div class="contacto__modal" role="dialog" aria-modal="true" aria-labelledby="contacto-modal-title" hidden>
    <div class="contacto__modal-backdrop" data-close></div>
    <div class="contacto__modal-card">
      <svg class="contacto__check" viewBox="0 0 52 52" aria-hidden="true">
        <circle class="contacto__check-circle" cx="26" cy="26" r="24" />
        <path class="contacto__check-mark" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8" />
      </svg>
      <h3 id="contacto-modal-title" class="contacto__modal-title">¡Mensaje enviado!</h3>
      <p class="contacto__modal-text">
        Gracias por escribirnos. Te respondemos dentro de las 24 hs.
      </p>
      <button type="button" class="contacto__modal-close" data-close>Cerrar</button>
    </div>
  </div>
</section>

<style>
  .contacto {
    padding-block: var(--space-section-y);
  }

  .contacto__inner {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  .contacto__title {
    font-size: var(--font-size-3xl);
    font-weight: var(--font-weight-medium);
    line-height: 1.15;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
    margin: var(--space-6) 0 var(--space-4);
  }

  .contacto__body {
    font-size: var(--font-size-md);
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin: 0 auto var(--space-8);
    max-width: 48ch;
  }

  .contacto__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    text-align: left;
  }

  .contacto__field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .contacto__label {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
  }

  .contacto__input {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    font: inherit;
    font-size: var(--font-size-base);
    color: var(--color-text-primary);
    background: var(--card-bg);
    border: var(--border-width) solid color-mix(in srgb, var(--color-text-primary) 16%, transparent);
    border-radius: var(--radius-md);
    /* Soft shadow + adaptive border so the fields read against the canvas
       in both light and dark themes (the flat card-bg alone blends in). */
    box-shadow:
      0 1px 2px color-mix(in srgb, var(--color-base-ink) 6%, transparent),
      0 4px 10px color-mix(in srgb, var(--color-base-ink) 8%, transparent);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .contacto__input:focus-visible {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 22%, transparent);
  }

  .contacto__input[aria-invalid='true'] {
    border-color: var(--color-accent);
  }

  .contacto__textarea {
    resize: vertical;
    min-height: 7rem;
  }

  .contacto__error {
    font-size: var(--font-size-xs);
    line-height: 1.4;
    color: var(--color-accent);
    min-height: 1em;
  }

  .contacto__honey {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  .contacto__status {
    margin: 0;
    font-size: var(--font-size-sm);
    line-height: 1.5;
    min-height: 1.5em;
    color: var(--color-text-primary);
  }

  /* --- Success modal --- */
  .contacto__modal[hidden] {
    display: none;
  }

  .contacto__modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: grid;
    place-items: center;
    padding: var(--space-6);
  }

  .contacto__modal-backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--color-base-ink) 55%, transparent);
    animation: contacto-fade 0.25s ease both;
  }

  .contacto__modal-card {
    position: relative;
    max-width: 400px;
    width: 100%;
    padding: var(--space-12) var(--space-8);
    text-align: center;
    background: var(--card-bg);
    border-radius: var(--card-radius);
    box-shadow: 0 24px 60px color-mix(in srgb, var(--color-base-ink) 30%, transparent);
    animation: contacto-pop 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  .contacto__check {
    width: 72px;
    height: 72px;
    margin: 0 auto var(--space-4);
    display: block;
  }

  .contacto__check-circle {
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 3;
    stroke-dasharray: 151;
    stroke-dashoffset: 151;
    animation: contacto-draw 0.5s ease-out 0.15s forwards;
  }

  .contacto__check-mark {
    stroke: var(--color-accent);
    stroke-width: 4;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 40;
    stroke-dashoffset: 40;
    animation: contacto-draw 0.3s ease-out 0.55s forwards;
  }

  .contacto__modal-title {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-2);
  }

  .contacto__modal-text {
    font-size: var(--font-size-md);
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-8);
  }

  .contacto__modal-close {
    font: inherit;
    font-size: var(--font-size-base);
    font-weight: var(--button-font-weight);
    color: var(--button-primary-text);
    background: var(--button-primary-bg);
    border: var(--border-width) solid var(--button-primary-bg);
    border-radius: var(--button-radius);
    padding: var(--button-padding-block) var(--button-padding-inline);
    min-height: var(--button-min-size);
    cursor: pointer;
    transition: filter 0.2s ease;
  }

  .contacto__modal-close:hover {
    filter: brightness(0.92);
  }

  @keyframes contacto-fade {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes contacto-pop {
    from {
      opacity: 0;
      transform: translateY(12px) scale(0.96);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes contacto-draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contacto__modal-backdrop,
    .contacto__modal-card,
    .contacto__check-circle,
    .contacto__check-mark {
      animation: none;
    }

    .contacto__check-circle,
    .contacto__check-mark {
      stroke-dashoffset: 0;
    }
  }

  @media (max-width: 809px) {
    .contacto__inner {
      padding-inline: var(--space-6);
    }

    .contacto__title {
      font-size: var(--font-size-xl);
      line-height: 1.12;
      letter-spacing: -0.05em;
    }
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>('.contacto__form');
  const status = document.querySelector<HTMLParagraphElement>('.contacto__status');
  const modal = document.querySelector<HTMLDivElement>('.contacto__modal');

  if (form && status && modal) {
    const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const closeBtn = modal.querySelector<HTMLButtonElement>('.contacto__modal-close');
    const fallbackUrl = status.dataset.fallback ?? '';
    let lastFocused: HTMLElement | null = null;

    // Rigorous email format check: local@domain.tld with a real TLD.
    const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;

    const rules: Record<string, (value: string) => string | null> = {
      nombre: (v) => (v.trim().length >= 2 ? null : 'Ingresá tu nombre.'),
      email: (v) => (EMAIL_RE.test(v.trim()) ? null : 'Ingresá un email válido, por ejemplo nombre@dominio.com.'),
      mensaje: (v) => (v.trim().length >= 10 ? null : 'Contanos un poco más (mínimo 10 caracteres).'),
    };

    const setError = (field: string, message: string | null) => {
      const input = form.querySelector<HTMLElement>(`[name="${field}"]`);
      const errorEl = document.getElementById(`contacto-${field}-error`);
      if (!input || !errorEl) return;
      errorEl.textContent = message ?? '';
      input.setAttribute('aria-invalid', message ? 'true' : 'false');
    };

    // Clear a field's error as the user fixes it.
    Object.keys(rules).forEach((field) => {
      const input = form.querySelector<HTMLInputElement>(`[name="${field}"]`);
      input?.addEventListener('input', () => {
        if (input.getAttribute('aria-invalid') === 'true') {
          setError(field, rules[field](input.value));
        }
      });
    });

    const validate = (): boolean => {
      let firstInvalid: HTMLElement | null = null;
      for (const field of Object.keys(rules)) {
        const input = form.querySelector<HTMLInputElement>(`[name="${field}"]`);
        if (!input) continue;
        const message = rules[field](input.value);
        setError(field, message);
        if (message && !firstInvalid) firstInvalid = input;
      }
      firstInvalid?.focus();
      return !firstInvalid;
    };

    const openModal = () => {
      lastFocused = document.activeElement as HTMLElement;
      modal.hidden = false;
      document.addEventListener('keydown', onKeydown);
      closeBtn?.focus();
    };

    const closeModal = () => {
      modal.hidden = true;
      document.removeEventListener('keydown', onKeydown);
      lastFocused?.focus();
    };

    const onKeydown = (event: KeyboardEvent) => {
      if (event.key === 'Escape') closeModal();
    };

    modal.querySelectorAll('[data-close]').forEach((el) => {
      el.addEventListener('click', closeModal);
    });

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!validate()) return;

      if (submitBtn) submitBtn.disabled = true;
      status.textContent = 'Enviando…';

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });
        const data = await response.json().catch(() => ({}));

        if (response.ok && String(data.success) === 'true') {
          form.reset();
          status.textContent = '';
          openModal();
        } else {
          throw new Error('submit failed');
        }
      } catch {
        status.innerHTML =
          'No pudimos enviar el mensaje. Escribinos por ' +
          `<a href="${fallbackUrl}" target="_blank" rel="noopener">WhatsApp</a>.`;
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  }
</script>
