---
import Logo from '../ui/Logo.astro';
import { WHATSAPP_URL } from '../../data/links';
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__brand">
      <Logo href="#contenido" />
      <p class="footer__tagline">Estrategia digital, web e IA</p>
    </div>
    <p class="footer__location">Mercedes, Buenos Aires, Argentina · Trabajamos con empresas de todo el país</p>
    <a class="footer__cta" href={WHATSAPP_URL} target="_blank" rel="noopener">
      Escribinos por WhatsApp
    </a>
  </div>
</footer>

<style>
  .footer {
    padding-block: var(--space-section-y);
    border-top: var(--border-width) solid var(--color-border-subtle);
  }

  .footer__inner {
    max-width: 1072px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer__tagline {
    margin: 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
  }

  .footer__location {
    margin: 0;
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .footer__cta {
    display: inline-flex;
    font-size: var(--font-size-sm);
    color: var(--color-accent);
    text-decoration: none;
    min-height: var(--size-touch);
    align-items: center;
  }

  .footer__cta:hover {
    text-decoration: underline;
  }

  @media (max-width: 809px) {
    .footer__inner {
      padding-inline: var(--space-6);
    }
  }
</style>
